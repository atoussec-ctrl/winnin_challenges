# API
NODE_ENV=development
API_PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/desafio
SQLITE_DATABASE_URL=file:./data/threads.sqlite
CORS_ALLOWED_ORIGINS=http://localhost:3001
RATE_LIMIT_MAX=100
RATE_LIMIT_TTL_MS=60000

# AI/RAG
# LLM_PROVIDER vazio usa o modelo de analise placeholder (sem credenciais).
# Valores aceitos: openai | openrouter | huggingface | ollama.
LLM_PROVIDER=
LLM_MODEL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=text-embedding-004
CHROMA_URL=http://localhost:8000
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=desafio-winnin

# Web
NEXT_PUBLIC_ANILIST_GRAPHQL_URL=https://graphql.anilist.co
NEXT_PUBLIC_API_URL=http://localhost:3333

# QA
SERVEREST_BASE_URL=http://localhost:3000
GE_BASE_URL=https://ge.globo.com

